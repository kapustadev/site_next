generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  PM
  EMPLOYEE
  CLIENT
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String?
  avatarUrl     String?
  role          Role      @default(EMPLOYEE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  projectsManaged  Project[]      @relation("ProjectManager")
  projectsAsClient Project[]      @relation("ProjectClient")
  projectMembers   ProjectMember[]
  tasksAssigned    Task[]         @relation("TaskAssignee")
  comments         Comment[]
  pluginVersions   PluginVersion[]
  messages         Message[]
  chatMembers      ChatMember[]
  wikiArticles     WikiArticle[]
  invoices         Invoice[]      @relation("InvoiceClient")
  serviceSubscriptions ServiceSubscription[] @relation("ClientSubscriptions")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  budget      Float?
  currency    Currency @default(PLN)
  budgetPln   Float?
  dueDate     DateTime?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  managerId   String?
  manager     User?    @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)

  clientId    String?
  client      User?    @relation("ProjectClient", fields: [clientId], references: [id], onDelete: SetNull)

  members     ProjectMember[]
  tasks       Task[]
  columns     KanbanColumn[]
  transactions Transaction[]
  invoices    Invoice[]
  chatGroups  ChatGroup[]
  serviceSubscriptions ServiceSubscription[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  joinedAt  DateTime @default(now())

  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model KanbanColumn {
  id           String   @id @default(cuid())
  name         String
  color        String   @default("#3b82f6")
  order        Int      @default(0)
  notifyClient Boolean  @default(false)
  createdAt    DateTime @default(now())

  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks        Task[]
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columnId    String?
  column      KanbanColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  comments    Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model PluginCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  plugins   Plugin[]
}

model Plugin {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())

  // Relations
  categoryId  String?
  category    PluginCategory? @relation(fields: [categoryId], references: [id])
  versions    PluginVersion[]
}

model PluginVersion {
  id          String   @id @default(cuid())
  version     String
  fileUrl     String
  createdAt   DateTime @default(now())

  pluginId    String
  plugin      Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  uploaderId  String
  uploader    User     @relation(fields: [uploaderId], references: [id])
}

// ─── УСЛУГИ (ХОСТИНГ И ДОМЕНЫ) ─────────────────────────────

enum ServiceType {
  HOSTING
  DOMAIN
  OTHER
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model ServiceSubscription {
  id          String       @id @default(cuid())
  name        String
  type        ServiceType
  price       Float
  currency    Currency     @default(PLN)
  billingCycle BillingCycle @default(YEARLY)
  nextDueDate DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  clientId    String
  client      User         @relation("ClientSubscriptions", fields: [clientId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

// ─── ФИНАНСЫ ───────────────────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
}

enum Currency {
  PLN
  USD
  EUR
  UAH
  GBP
  CHF
  CZK
  HUF
}

model Transaction {
  id          String          @id @default(cuid())
  amount      Float
  type        TransactionType
  category    String
  description String?
  date        DateTime        @default(now())

  projectId   String?
  project     Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model ExchangeRateCache {
  id          String   @id @default(cuid())
  currency    String   @unique
  rateToPln   Float
  fetchedAt   DateTime @default(now())
}

// ─── ФАКТУРЫ (БИЛЛИНГ) ─────────────────────────────────────

model Invoice {
  id          String   @id @default(cuid())
  amount      Float
  status      InvoiceStatus @default(PENDING)
  description String?
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId    String
  client      User     @relation("InvoiceClient", fields: [clientId], references: [id], onDelete: Cascade)
}

// ─── КОММУНИКАЦИИ ──────────────────────────────────────────

model ChatGroup {
  id          String   @id @default(cuid())
  name        String
  isDirect    Boolean  @default(false)
  createdAt   DateTime @default(now())

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  members     ChatMember[]
  messages    Message[]
}

model ChatMember {
  id         String   @id @default(cuid())
  joinedAt   DateTime @default(now())
  lastReadAt DateTime?

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId   String
  group     ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Message {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())

  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  groupId   String
  group     ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

// ─── БАЗА ЗНАНИЙ (WIKI) ────────────────────────────────────

model WikiArticle {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}
